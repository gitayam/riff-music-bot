# Copy to .env and fill in real values. .env is gitignored; this template is committed.
# run.sh sources .env and injects these as ZEROCLAW_* config overrides at runtime,
# so no real secret ever lands in config.toml.

# --- LLM provider (Mistral) ---
# In this setup, reused from hermes' MISTRAL_HERMES (ai-coding-env/docs/qubes/.env).
MISTRAL_API_KEY=

# --- Discord application / bot (https://discord.com/developers/applications) ---
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- Supabase (frontend + persistence) ---
# URL + publishable key are public-by-design (safe to commit here). The SECRET
# key must NOT be committed — put it only in the gitignored .env.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# --- Modal: Stable Audio 3 generation endpoints ---
MODAL_TEXT_TO_AUDIO=https://<workspace>--stable-audio-3-server-stableaudio3-text-to-audio.modal.run/
MODAL_AUDIO_TO_AUDIO=https://<workspace>--stable-audio-3-server-stableaudio3-audio-to-audio.modal.run/
