# Copy to worker/.dev.vars (gitignored) for `wrangler dev`. NEVER commit real values.
# In prod these two are set via `npx wrangler secret put <NAME>` instead.
OPENAI_API_KEY=sk-...          # the gpt-5.4 key (locally: zeroclaw/.env OPENAI_API)
MUSIC_API_TOKEN=choose-a-long-random-string   # the bearer other groups must send on every POST
# Optional overrides (also settable in wrangler.toml [vars]):
# OPENAI_MODEL=gpt-5.4
# OPENAI_BASE_URL=https://api.openai.com/v1
